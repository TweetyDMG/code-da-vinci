# ═══════════════════════════════════════════════════
# Code Da Vinci — Environment Variables
# ═══════════════════════════════════════════════════
# Скопируй этот файл в .env и заполни свои значения:
#   cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── База данных PostgreSQL ───────────────────────
DB_URL=jdbc:postgresql://localhost:5432/course_project
DB_USER=app_user
DB_PASSWORD=1234
DB_POOL_SIZE=10

# ─── Конфигурация приложения ──────────────────────
# Максимальный размер загружаемого аватара (в байтах)
MAX_FILE_SIZE=10485760
